# Optional — only needed when the API is not on localhost:3000
# or when building for production (no Vite dev proxy).

# Backend API origin (no trailing slash). Examples:
#   http://localhost:3000
#   https://api.kube-memory.example.com
#
# If unset:
#   - dev: browser calls /api → Vite proxies to http://localhost:3000
#   - build: MCP snippets use same-origin /api/mcp (set this for a separate API host)
VITE_API_URL= 
