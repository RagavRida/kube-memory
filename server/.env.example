# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/kube-memory

# Cognee Cloud REST API
COGNEE_BASE_URL=https://api.cognee.ai
COGNEE_API_KEY=
COGNEE_TENANT_ID=

# Auth — bootstrap key for dev when no Mongo keys exist (optional)
MASTER_API_KEY=

# API key hashing salt (required in production)
API_KEY_SALT=

# Kubernetes (optional, Phase 2)
KUBECONFIG_BASE64=

# Vercel Cron secret (optional)
CRON_SECRET=

# Dashboard auth (JWT + GitHub OAuth)
JWT_SECRET=
JWT_EXPIRES_IN=7d
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Google Cloud connector OAuth
GCP_OAUTH_CLIENT_ID=
GCP_OAUTH_CLIENT_SECRET=
GCP_OAUTH_CALLBACK_URL=http://localhost:3000/connectors/gcp/oauth/callback

CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Connector secret encryption (min 32 chars)
CONNECTOR_ENCRYPTION_KEY=
